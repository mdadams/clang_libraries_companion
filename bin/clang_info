################################################################################

import glob
import json
import os
from pathlib import Path
import re
from shlex import quote
import subprocess
import sys
from typing import Optional

################################################################################

debug_level=0

def eprint(*args, **kwargs):
    print(*args, file = sys.stderr, **kwargs)

def quote_command_line(args):
    return ' '.join(quote(arg) for arg in args);

def run_program(args):
    try:
        result = subprocess.run(args, stdout=subprocess.PIPE,
          stderr=subprocess.PIPE, text=True, check=True)
        if result.returncode == 0:
            return {"status": result.returncode, "stdout": result.stdout}
        return {"status": result.returncode}
    except subprocess.CalledProcessError as e:
        return {"status": -1, "exception": e}

################################################################################

def is_ccache(path: Path) -> bool:
    # Check if any component of the parent path contains "ccache".
    for part in path.parent.parts:
        if "ccache" in part.lower():
            return True
    # Check if the resolved canonical path's basename contains "ccache".
    try:
        canonical = path.resolve()
        if 'ccache' in canonical.name.lower():
            return True
    except OSError:
        pass
    return False


def is_clang(path: Path, regexes: list[str]) -> bool:
    try:
        canonical = path.resolve()
        for pattern in [re.compile(r) for r in regexes]:
            if pattern.fullmatch(canonical.name):
                return True
    except OSError:
        pass
    return False

def find_program(regexes: list[str], search_path: list[str],
  first_match: bool = True,) -> list[str]:
    compiled = [re.compile(r) for r in regexes]
    results = []
    seen = set()
    for pattern in compiled:
        for directory in search_path:
            dir_path = Path(directory)
            if not dir_path.is_dir():
                continue
            try:
                entries = sorted(dir_path.iterdir())
            except PermissionError:
                continue
            for entry in entries:
                if not entry.is_file() and not entry.is_symlink():
                    continue
                if not os.access(entry, os.X_OK):
                    continue
                if not pattern.fullmatch(entry.name):
                    continue
                if is_ccache(entry):
                    continue
                resolved = str(entry.resolve())
                if resolved in seen:
                    continue
                seen.add(resolved)
                results.append(str(entry))
                if first_match:
                    return results
    return results

def find_compiler(name):
    if name == "clang++":
        env_var = "CXX"
        prog_name = "clang++"
    else:
        env_var = "CC"
        prog_name = "clang"
    regexes = [
        re.escape(prog_name),
        re.escape(prog_name) + r"(-\d+)?",
    ]
    prog_path = os.environ.get(env_var)
    if prog_path is not None:
        prog_pathobj = Path(prog_path)
        if (prog_pathobj.is_absolute() and prog_pathobj.exists() and
          os.access(prog_pathobj, os.X_OK) and is_clang(prog_pathobj, regexes)):
            return prog_path
    search_path = os.environ.get("PATH", "").split(os.pathsep)
    matches = find_program(regexes, search_path, first_match=True)
    if not matches:
        return None
    return matches[0]

################################################################################

def parse_clang_version_output(output: str) -> dict:
    result = {}
    lines = output.strip().splitlines()
    if debug_level >= 1:
        eprint(f"VERSION OUTPUT:\n{lines}")
    if lines:
        m = re.match(r'clang version\s+(\S+)', lines[0])
        if m:
            version = m.group(1)
            result['version'] = version
            vm = re.match(r'(\d+)\.(\d+)\.(\d+)(.*)', version)
            if vm:
                result['major_version'] = int(vm.group(1))
                result['minor_version'] = int(vm.group(2))
                result['patch_version'] = int(vm.group(3))
                pre = vm.group(4).lstrip('-')
                if pre:
                    result['pre_release'] = pre
        for line in lines[1:]:
            if ':' in line:
                key, _, value = line.partition(':')
                key = re.sub(r'\s+', '_', key.strip()).lower()
                result[key] = value.strip()
    return result

def run_clang_version(clang_program_path):
    args = [clang_program_path, "--version"]
    if debug_level >= 1:
        eprint(f"running: {quote_command_line(args)}")
    run_result = run_program(args)
    if run_result["status"] != 0:
        return None
    parsed = parse_clang_version_output(run_result["stdout"])
    info = {
        "version_name": parsed["version"],
        "version_major": parsed["major_version"],
        "version_minor": parsed["minor_version"],
        "version_patch": parsed["patch_version"],
        "target": parsed["target"],
        "bin_dir": parsed["installeddir"],
        #"build_config": parsed["build_config"] if "build_config" in parsed else "",
    }
    return info

def run_clang_print_resource_dir(clang_program_path):
    if debug_level >= 1:
        eprint(f"running: {clang_program_path} -print-resource-dir")
    args = [clang_program_path, "-print-resource-dir"]
    run_result = run_program(args)
    if run_result["status"] != 0:
        return None
    resource_dir = run_result["stdout"].splitlines()[0]
    return resource_dir

################################################################################

def main():

    global debug_level
    keys = sys.argv[1:]
    json_format = (len(keys) == 0)
    debug = os.environ.get("CL_CLANG_INFO_DEBUG")
    if debug is not None:
        debug_level = 1

    resource_dir = os.environ.get("CL_CLANG_RESOURCE_DIR")
    if resource_dir is not None:
        resource_dir_pathobj = Path(resource_dir)
        if not (resource_dir_pathobj.exists() and
          resource_dir_pathobj.is_dir()):
            resource_dir = None
    if resource_dir is None:
        override = False
        clangxx_prog_path = find_compiler("clang++")
        clang_prog_path = find_compiler("clang")
        install_dir = str(Path(clangxx_prog_path).parent.parent)
        version_info = run_clang_version(clangxx_prog_path)
        resource_dir = run_clang_print_resource_dir(clangxx_prog_path)
    else:
        override = True
        install_dir = str(Path(resource_dir).parent.parent.parent)
        version_info = None
        clangxx_prog_path = None
        clang_prog_path = None
        major_version = None
    resource_include_dir = str(Path(resource_dir) / "include")
    info = {
        "install_dir": install_dir,
        "resource_dir": resource_dir,
        "resource_include_dir": resource_include_dir,
    }
    if not override:
        info.update({
            **version_info,
            "clangxx_path": clangxx_prog_path,
            "clang_path": clang_prog_path,
        })
    else:
        if major_version is not None:
            info["major_version"] = major_version
    aliases = {
        "include_dir": "resource_include_dir",
    }
    if json_format:
        print(json.dumps(info, indent=2))
    else:
        for key in keys:
            if key in aliases:
                key = aliases[key]
            print(info[key] if key in info else "")

################################################################################

if __name__ == "__main__":
    sys.exit(main())
